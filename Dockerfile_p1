# ─────────────────────────────────────────────
# Imagen base
# ─────────────────────────────────────────────
FROM python:3.12-slim

# ─────────────────────────────────────────────
# Metadatos
# ─────────────────────────────────────────────
LABEL maintainer="ekonjmrivas-devops"
LABEL description="FastAPI Hello World - Práctica Docker"
LABEL version="1.0"

# ─────────────────────────────────────────────
# ARG — parámetros de compilación (build-time)
# ─────────────────────────────────────────────
ARG APP_USER=appuser
ARG APP_DIR=/app

# ─────────────────────────────────────────────
# ENV — variables de entorno (runtime)
# ─────────────────────────────────────────────
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_HOME=${APP_DIR}

# ─────────────────────────────────────────────
# Directorio de trabajo
# ─────────────────────────────────────────────
WORKDIR ${APP_DIR}

# ─────────────────────────────────────────────
# Copiar código fuente
# ─────────────────────────────────────────────
COPY . .

# ─────────────────────────────────────────────
# Instalación de dependencias
# ─────────────────────────────────────────────
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# ─────────────────────────────────────────────
# Usuario no root (seguridad)
# ─────────────────────────────────────────────
RUN useradd --no-create-home --shell /bin/false ${APP_USER}
USER ${APP_USER}

# ─────────────────────────────────────────────
# Puerto expuesto
# ─────────────────────────────────────────────
EXPOSE 8000

# ─────────────────────────────────────────────
# Comando de arranque
# ─────────────────────────────────────────────
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
